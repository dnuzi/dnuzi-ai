{
  "name": "dnuzi",
  "version": "0.0.1",
  "description": "Dnuzi AI - Powered by DanuZz.",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "exports": {
    ".": {
      "require": "./lib/index.cjs",
      "import": "./lib/index.mjs"
    }
  },
  "bin": {
    "dnuzi": "./bin/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "prepublishOnly": "node scripts/build.js",
    "test": "jest --coverage --forceExit"
  },
  "keywords": [
    "dnuzi",
    "ai",
    "cli",
    "chatbot",
    "danuZz",
    "developer-tools",
    "terminal",
    "agentic",
    "assistant"
  ],
  "author": "DanuZz (@dnuzi)",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "boxen": "^6.2.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "conf": "^10.2.0",
    "dayjs": "^1.11.21",
    "figlet": "^1.11.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.12",
    "marked": "^11.1.0",
    "marked-terminal": "^6.2.0",
    "mongodb": "^6.3.0",
    "ora": "^5.4.1",
    "readline": "^1.3.0",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "lib/",
    "src/",
    "scripts/",
    "python/",
    "html/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dnuzi/dnuzi-ai"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nock": "^14.0.15"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "lib/**/*.js"
    ],
    "testTimeout": 15000
  }
}